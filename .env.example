# news-alert 환경변수 템플릿
# 이 파일을 복사해서 .env로 저장하고 본인 키를 채워 넣으세요
# .env는 .gitignore에 포함되어 있어 커밋되지 않습니다

# ── Python 푸시서버용 (news-push-server.py가 읽음) ──
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── Expo 앱 빌드용 (EXPO_PUBLIC_ 접두사는 JS 번들에 포함됨 = 공개) ──
EXPO_PUBLIC_NAVER_CLIENT_ID=
EXPO_PUBLIC_NAVER_CLIENT_SECRET=

# ── Firebase (현재 앱 코드상 실사용 없음 — 빈 값이어도 빌드됨) ──
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
